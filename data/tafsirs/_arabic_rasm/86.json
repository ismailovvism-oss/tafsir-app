{"1":"ٮسم الله الرحمں الرحىم والسماء والطارٯ","2":"وما ادراك ما الطارٯ","3":"الںحم الٮاٯٮ","4":"اں كل ںڡس لما علىها حاڡط","5":"ڡلىںطر الاںساں مم حلٯ","6":"حلٯ مں ماء داڡٯ","7":"ىحرح مں ٮىں الصلٮ والٮراىٮ","8":"اںه على رحعه لٯادر","9":"ىوم ٮٮلى السراىر","10":"ڡما له مں ٯوه ولا ںاصر","11":"والسماء داٮ الرحع","12":"والارص داٮ الصدع","13":"اںه لٯول ڡصل","14":"وما هو ٮالهرل","15":"اںهم ىكىدوں كىدا","16":"واكىد كىدا","17":"ڡمهل الكاڡرىں امهلهم روىدا"}