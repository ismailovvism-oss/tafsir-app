{"1":"بسم الله الرحمن الرحيم والليل إذا يغشى","2":"والنهار إذا تجلى","3":"وما خلق الذكر والأنثى","4":"إن سعيكم لشتى","5":"فأما من أعطى واتقى","6":"وصدق بالحسنى","7":"فسنيسره لليسرى","8":"وأما من بخل واستغنى","9":"وكذب بالحسنى","10":"فسنيسره للعسرى","11":"وما يغني عنه ماله إذا تردى","12":"إن علينا للهدى","13":"وإن لنا للآخرة والأولى","14":"فأنذرتكم نارا تلظى","15":"لا يصلاها إلا الأشقى","16":"الذي كذب وتولى","17":"وسيجنبها الأتقى","18":"الذي يؤتي ماله يتزكى","19":"وما لأحد عنده من نعمة تجزى","20":"إلا ابتغاء وجه ربه الأعلى","21":"ولسوف يرضى"}