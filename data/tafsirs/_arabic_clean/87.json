{"1":"بسم الله الرحمن الرحيم سبح اسم ربك الأعلى","2":"الذي خلق فسوى","3":"والذي قدر فهدى","4":"والذي أخرج المرعى","5":"فجعله غثاء أحوى","6":"سنقرئك فلا تنسى","7":"إلا ما شاء الله إنه يعلم الجهر وما يخفى","8":"ونيسرك لليسرى","9":"فذكر إن نفعت الذكرى","10":"سيذكر من يخشى","11":"ويتجنبها الأشقى","12":"الذي يصلى النار الكبرى","13":"ثم لا يموت فيها ولا يحيى","14":"قد أفلح من تزكى","15":"وذكر اسم ربه فصلى","16":"بل تؤثرون الحياة الدنيا","17":"والآخرة خير وأبقى","18":"إن هذا لفي الصحف الأولى","19":"صحف إبراهيم وموسى"}