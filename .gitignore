# OS / editor
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Python
__pycache__/
*.pyc

# Temp
*.log
*.tmp

# Raw build sources (large; re-fetched by build scripts). The built runtime
# data under data/wbw/ IS committed.
data/_sources/

# Бинарные данные сканов — на Cloudflare R2, в репозиторий не коммитим.
# Карты страниц (data/img/<id>/<sura>.json, _about.json) ОСТАЮТСЯ в репо.
data/img/**/*.webp
data/img/**/*.png
data/img/**/*.jpg
# Аудио-тилява (задел; на объектном хранилище)
data/audio/

# Тяжёлые тафсиры на Cloudflare R2 (поле dataBase в config). В репо НЕ коммитим
# ни монолит, ни чанки, ни индекс — они лежат на R2 (и локально для пересборки;
# пересоздаются скриптами по сырью). См. CHANGELOG «Источники на R2».
data/tafsirs/mawsua_masur.json
data/tafsirs/mawsua_masur.js
data/tafsirs/mawsua_masur/
data/index/mawsua_masur.json
